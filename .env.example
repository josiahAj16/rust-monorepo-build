# ============================================================================
# LOGGING
# ============================================================================

# Rust logging level: debug, info, warn, error
RUST_LOG=conch_backend=debug,tower_http=debug,sqlx=debug

# Node logging level
LOG_LEVEL=debug

# ============================================================================
# ENVIRONMENT
# ============================================================================

# Environment: development, production
RUST_ENV=development
NODE_ENV=development

# ============================================================================
